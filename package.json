{
  "name": "churchbulletin",
  "version": "1.0.0",
  "description": "A simple, single-file web application for creating weekly church bulletins at St. Michael Ukrainian Catholic Church in Terryville, CT.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && shx cp dist/index.html dist/StMike_Bulletin_Generator.html",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.8.9",
    "prettier": "^3.8.1",
    "shx": "^0.4.0",
    "vite": "^8.0.3",
    "vite-plugin-singlefile": "^2.3.2",
    "vitest": "^4.1.2"
  }
}
